# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains credentials.

# Your Google Cloud project ID
# Find it at console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery dataset name (will be created automatically if it doesn't exist)
BIGQUERY_DATASET=marketing_weather

# BigQuery table name
BIGQUERY_TABLE=hourly_conditions

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# GOOGLE_APPLICATION_CREDENTIALS is handled by the gcloud CLI
# after you run: gcloud auth application-default login
# You don't need to set it here if you've done that.
